{
  "schema_version": 1,
  "title": "The Chaotic Caves",
  "hooks": [
    "Treasure recovery and monster exterminators are needed because monster attacks near the frontier town have recently increased.",
    "Locals offer rumors of monster activity in the wilderness, including orcs, goblins, gnolls, lizard men, bandits, ghouls near old crypts, and possible spell-casting attackers.",
    "The heroes can explore the marked wilderness sites, recover loot from monsters, rescue captives, and root out the caves threatening nearby towns and villages."
  ],
  "town": {
    "name": "",
    "description": "An unnamed frontier town on the border between wilderness and civilized lands, beside a river and bridge and protected by a wooden stockade being replaced by a stone wall. It serves as the local home base, with merchants, taverns, craftsmen, church, healer, garrison, militia, docks, warehouse, and many residences."
  },
